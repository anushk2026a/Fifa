# ── Server ──────────────────────────────────────────────────────────────────────
PORT=4000

# Local dev:
NODE_ENV=development
# Production (copy into Render):
#NODE_ENV=production

# ── CORS ────────────────────────────────────────────────────────────────────────

# Local dev:
CORS_ORIGIN=http://localhost:3000

# Production (copy into Render):
#CORS_ORIGIN=https://sportsonepoint.vercel.app

# ── Admin auth (news dashboard) ───────────────────────────────────────────────────
# Used by `npm run seed` to create the admin and to sign login tokens.
# CHANGE THESE before deploying to production.
JWT_SECRET=dev-insecure-secret-change-me
JWT_EXPIRES_IN=7d
ADMIN_EMAIL=adminfifa@gmail.com
ADMIN_PASSWORD=123456

# ── Storage ───────────────────────────────────────────────────────────────────────
# News is stored in MongoDB when MONGODB_URI is set; otherwise it falls back to
# a local JSON file under DATA_DIR. (Admin accounts always use the JSON file.)
DATA_DIR=data

# Paste your real MongoDB connection string in .env (NOT here). Either name works:
# MONGODB_URI=...  or  MONGO_URI=...
#MONGO_URI=mongodb+srv://user:pass@cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=sportsonepoint

