# Copy to ".env" and fill in. Never commit the real .env.

# Server
PORT=4000
NODE_ENV=development

# Comma-separated list of allowed origins (the frontend URL). Use * only in dev.
# e.g. https://sportsonepoint.com,https://www.sportsonepoint.com
CORS_ORIGIN=http://localhost:3000

# SMTP — required for the contact form to actually send email.
# Works with any SMTP provider (Gmail App Password, Zoho, Brevo, Mailgun, SES SMTP, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# From address used on outgoing mail, and where contact submissions are delivered.
MAIL_FROM=SportsOnePoint <no-reply@sportsonepoint.com>
CONTACT_TO=
