# ── Server ──────────────────────────────────────────────────────────────────────
PORT=4000

# Local dev:
NODE_ENV=development
# Production (copy into Render):
#NODE_ENV=production

# ── CORS ────────────────────────────────────────────────────────────────────────

# Local dev:
CORS_ORIGIN=http://localhost:3000

# Production (copy into Render):
#CORS_ORIGIN=https://sportsonepoint.vercel.app

# ── SMTP (Gmail App Password) ────────────────────────────────────────────────────
# Required for the contact form to send email.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=xxxxxxxxx@gmail.com
# Paste your Gmail App Password (no spaces):
SMTP_PASS=xxxxxxxxxx

# ── Mail addresses ───────────────────────────────────────────────────────────────
MAIL_FROM=SportsOnePoint <anushk2026a@gmail.com>
# Where contact form submissions are delivered:
CONTACT_TO=xxxxxxxxxxxx@gmail.com
