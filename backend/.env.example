# ── Server ──────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
# Production:
#NODE_ENV=production

# ── CORS ────────────────────────────────────────────────────────────────────────
# Comma-separated, no spaces.  Used as the allowlist for Access-Control-Allow-Origin.
# Local dev:
CORS_ORIGIN=http://localhost:3000
# Production (Render):
#CORS_ORIGIN=https://www.fifaonepoint.com,https://fifaonepoint.com,https://SportsOnePoint.vercel.app

# ── Auth ─────────────────────────────────────────────────────────────────────────
# REQUIRED in production — must be ≥32 random characters each.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=dev-insecure-jwt-secret-change-me
JWT_REFRESH_SECRET=dev-insecure-refresh-secret-change-me

# Access token lifetime (short — clients refresh via POST /auth/refresh).
JWT_EXPIRES_IN=15m
# Refresh token lifetime in milliseconds (default 7 days).
REFRESH_TOKEN_EXPIRES_IN_MS=604800000

ADMIN_EMAIL=adminfifa@gmail.com
# REQUIRED in production — must be ≥8 characters.
ADMIN_PASSWORD=dev-change-me-123

# ── Storage ───────────────────────────────────────────────────────────────────────
# News + matches stored in MongoDB when MONGODB_URI is set; JSON file store otherwise.
DATA_DIR=data
# Either name works:
# MONGODB_URI=mongodb+srv://user:pass@cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority
# MONGO_URI=...
MONGODB_DB=fifaonepoint

# ── SMTP ─────────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_TO=

# ── Cloudinary ────────────────────────────────────────────────────────────────────
# Get these from https://console.cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
